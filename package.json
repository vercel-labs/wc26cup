    "motion": "12.40.0",
    "nanoid": "5.1.11",
    "next": "^16.1.0",
    "radix-ui": "1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "satori": "^0.26.0",
    "shiki": "4.1.0",
    "streamdown": "^2.0.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "use-stick-to-bottom": "1.1.4",
    "zod": "4.4.3"
